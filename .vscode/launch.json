{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Cortex Debug",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "flash-and-run",
            "executable": "./executable.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "openOCDLaunchCommands": ["debug_level"],
            "device": "STM32L5x",
            "configFiles": [
                "interface/stlink-v2-1.cfg",
                "target/stm32l5x.cfg"
            ],
            "console": "none",
            "svdFile": "./STM32L552.svd",
            "showDevDebugOutput": "raw",
            "presentation": {
                "reveal": "silent",
                "revealProblems": "onProblem",
                "close": true
            }
        },

        {
        "name": "Flash and Run",
        "type": "node",
        "request": "launch",
        "preLaunchTask": "flash-and-run",
        "cwd": "${workspaceFolder}",
        "runtimeExecutable": "/bin/ls"
        },
        
        {
        "name": "DFU Flash and Run",
        "type": "node",
        "request": "launch",
        "preLaunchTask": "dfu-flash-and-run",
        "cwd": "${workspaceFolder}",
        "runtimeExecutable": "/bin/ls"
        }

    ]
}